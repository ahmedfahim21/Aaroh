# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# The following keys below are automatically created and
# added to your environment when you deploy on Vercel

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=****

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=****


# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****


# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****

# MCP Commerce Server Configuration
MCP_MERCHANT_URL=http://localhost:8000
MCP_MERCHANT_NAME=Artisan India

# Privy wallet connect — required for auth
# Get your app ID at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Agent service URL (defaults to http://localhost:8004)
AGENT_URL=http://localhost:8004
# Same secret as agent.py AGENT_API_SECRET when you enable Bearer auth on the agent
# AGENT_API_SECRET=

# x402 USDC payment network — must match the chain used in shopping/evm.py
X402_NETWORK=eip155:84532

# URL of the merchant app (for cross-app redirects)
NEXT_PUBLIC_MERCHANT_APP_URL=http://localhost:3001
