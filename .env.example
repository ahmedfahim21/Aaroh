# Root-level env for agent.py, mcp_client.py, and other `uv run` commands from this repo.
# Copy to `.env` in the same directory (repo root):  cp .env.example .env
#
# Next.js apps use their own files: consumer/.env.local, merchant/.env.local — those are NOT loaded here.

# ── Required for autonomous shopping loop (same name as consumer/.env.local) ──
GOOGLE_GENERATIVE_AI_API_KEY=
# Deprecated alias still supported in code: GEMINI_API_KEY=

# ── Consumer app “Agents” feature (POST /agents + encrypted key store) ──
AGENT_KEY_ENCRYPTION_SECRET=
# Same random string as consumer/.env.local AGENT_API_SECRET when you enable it:
# AGENT_API_SECRET=
# AGENT_KEYS_STORE=.agent_keys.json

# ── Optional: global demo wallet (AGENT_TASK, /shop without consumer_agent_id, GET /identity) ──
# AGENT_PRIVATE_KEY=0x...

# ── Optional EIP-8004 (Base Sepolia) for the global AGENT_PRIVATE_KEY wallet ──
# ERC8004_IDENTITY_REGISTRY=0x...
# ERC8004_REPUTATION_REGISTRY=0x...
# IDENTITY_REGISTRY_RPC=https://sepolia.base.org
# PINATA_JWT=eyJ...   # For pinning agent.json manifests to IPFS via Pinata

# ── Defaults ──
# GEMINI_MODEL=gemini-2.5-flash
# X402_NETWORK=eip155:84532
# UCP merchant base URL(s) for list_merchants / find_merchant (required for discovery without hardcoded hosts)
# MERCHANT_URL=https://your-merchant.example
# MERCHANT_URLS=https://store-a.example,https://store-b.example

# ── Optional: run one task on agent.py startup (uses global key, not consumer agents) ──
# AGENT_TASK=
